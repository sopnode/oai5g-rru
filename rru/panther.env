RRU_TYPE="aw2s"

# comment followings parameters to get the default values

#GNB_REPO="docker.io/oaisoftwarealliance/oai-gnb-aw2s"
GNB_REPO="docker.io/r2labuser/oai-gnb-aw2s"
DU_REPO="docker.io/r2labuser/oai-gnb-aw2s"
CU_REPO="docker.io/r2labuser/oai-gnb-aw2s"
CUCP_REPO="docker.io/r2labuser/oai-gnb-aw2s"

#GNB_TAG="2025.w52"

MULTUS_GNB_RU="true"
IF_NAME_GNB_RU="r2lab_aw2s"
IP_GNB_RU="dhcp" # "192.168.233.104"
#VLAN_GNB_RU="3011"

ADDR_RU="192.168.236.103"

# setting QOS to true prevent cpu core pinning
QOS_GNB="false"
QOS_DU="false"

ADD_OPTIONS_GNB="--thread-pool  17,19,21,23,25,27,29,31 --log_config.global_log_options level,nocolor,time"