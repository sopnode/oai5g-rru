# Image configuration
.nfimage.repository          = strenv(CUUP_REPO) |
.nfimage.version             = strenv(CUUP_TAG) |
.nfimage.pullPolicy          = strenv(CUUP_PULL_POLICY) |

# Common gNB / NF config
.config.useAdditionalOptions = strenv(ADD_OPTIONS_CUUP) |
.config.cucpHost             = strenv(HOST_CUCP) |
.config.enableE2             = (strenv(FLEXRIC) == "true") |
.config.ricHost              = strenv(HOST_FLEXRIC) |
.config.tac                  = strenv(TAC) |

.start.tcpdump               = (strenv(PCAP) == "true") |
.includeTcpDumpContainer     = (strenv(LOGS) == "true") |
.persistent.sharedvolume     = (strenv(PCAP) == "true") |

.resources.define            = (strenv(QOS_CUUP) == "true") |
.nodeName                    = strenv(NODE_CUUP)
